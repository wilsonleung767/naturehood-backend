# Copy this file to .env and fill in real values before running docker compose.
# .env is in .gitignore and .dockerignore — it must never be committed.
#
# IMPORTANT — line endings:
#   Save this file with Unix line endings (LF, not CRLF).
#   On Windows: in VS Code click "CRLF" in the status bar and switch to "LF",
#   or run:  git config core.autocrlf false  before editing.
#   CRLF causes a \r to be appended to every value inside the container,
#   breaking passwords, URIs, and channel names silently.

# ── Redis ──────────────────────────────────────────────────────────────────────
# Shared password between the Redis container and the backend.
REDIS_PASSWORD=changeme

# These two are the Spring-canonical env var names that map directly to
# spring.data.redis.host and spring.data.redis.password in application.properties.
# docker-compose.yml already sets SPRING_DATA_REDIS_HOST=redis for you.
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PASSWORD=changeme

# ── MongoDB (Atlas or self-hosted) ────────────────────────────────────────────
# Plain string — no quotes needed. Special characters in the password must be
# percent-encoded (e.g. @ → %40, # → %23).
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority

# Local MongoDB service credentials (used by docker-compose mongodb service)
MONGO_ROOT_USERNAME=naturehood_admin
MONGO_ROOT_PASSWORD=change_this_long_password
MONGO_DATABASE=naturehood

# ── Supabase JWT ──────────────────────────────────────────────────────────────
# Plain strings — no quotes, no escaping needed. Just paste the full URL as-is.
SUPABASE_JWKS_URI=https://your-project-ref.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_ISSUER_URI=https://your-project-ref.supabase.co/auth/v1

# Supabase project URL + service-role key (required for AI usage reset cron)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Feed algorithm tuning (optional — defaults shown) ─────────────────────────
FEED_TIMELINE_MAX_SIZE=2000
FEED_DEFAULT_PAGE_SIZE=20
FEED_SCORE_RECENCY_WEIGHT=0.5
FEED_SCORE_ENGAGEMENT_WEIGHT=0.3
FEED_SCORE_AFFINITY_WEIGHT=0.2
FEED_EXPLORE_MAX_INJECT_PER_POST=50
FEED_EXPLORE_LOOKBACK_HOURS=48
FEED_WARMUP_LOOKBACK_HOURS=72

# ── SSE ───────────────────────────────────────────────────────────────────────
SSE_EMITTER_TIMEOUT_MS=300000

# ── Redis Pub/Sub channel ─────────────────────────────────────────────────────
REDIS_CHANNEL_FEED=channel:feed

# ── Kafka (optional — only needed if Kafka is in use) ────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO